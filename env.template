# env.template — Copy to .env and fill in your values
# NEVER commit .env to git

# ── Upstox API ──────────────────────────────────────────────────────────────
UPSTOX_API_KEY=your_upstox_api_key_here
UPSTOX_API_SECRET=your_upstox_api_secret_here
UPSTOX_REDIRECT_URI=http://localhost

# Generated daily by running: python scripts/auth.py <auth_code>
UPSTOX_ACCESS_TOKEN=

# Set to sandbox URL for paper trading:
# UPSTOX_BASE_URL=https://sandbox-api.upstox.com/v2
# Set to live URL for real trading:
# UPSTOX_BASE_URL=https://api.upstox.com/v2
UPSTOX_BASE_URL=https://api.upstox.com/v2

# ── Paper Trading ───────────────────────────────────────────────────────────
# "true" = paper mode (orders logged to memory/paper_portfolio.json)
# "false" = live trading (real orders placed)
PAPER_TRADING=true

# ── Telegram Notifications ──────────────────────────────────────────────────
# Setup (2 minutes):
#   1. Open Telegram → search @BotFather → send /newbot
#   2. Follow prompts → get your BOT_TOKEN (looks like: 123456789:AAF...)
#   3. Open your new bot and send it any message (e.g. "hello")
#   4. Visit: https://api.telegram.org/bot<TOKEN>/getUpdates in browser
#   5. Find "chat":{"id": XXXXXXXXX} — that is your CHAT_ID
TELEGRAM_BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=your_numeric_chat_id

# ── Gemini API (Google Search grounding) ────────────────────────────────────
# Free tier: 1,500 requests/day — no credit card needed
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── TF Suppression (no changes needed) ─────────────────────────────────────
TF_ENABLE_ONEDNN_OPTS=0
TF_CPP_MIN_LOG_LEVEL=3
